<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <object id="window" class="AdwWindow">
        <property name="default-width">800</property>
        <property name="default-height">400</property>
        <child>
            <object class="AdwToolbarView">
                <child type="top">
                    <object class="AdwHeaderBar">
                        <property name="title-widget">
                            <object class="AdwWindowTitle">
                                <property name="title" translatable="yes">Demo</property>
                                <property name="subtitle" translatable="yes">Soon to be simulated</property>
                            </object>
                        </property>
                    </object>
                </child>
                <property name="content">
                    <object class="GtkPaned">
                        <property name="orientation">horizontal</property>
                        <child>
                            <object class="GtkLabel">
                                <property name="label" translatable="yes">Hello World!</property>
                            </object>
                        </child>
                        <child>
                            <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <child>
                                    <object class="AdwTabBar">
                                        <property name="view">tab_view</property>
                                    </object>
                                </child>
                                <child>
                                    <object id="tab_view" class="AdwTabView">
                                        <property name="hexpand">true</property>
                                        <property name="vexpand">true</property>

                                        <child>
                                            <object class="AdwTabPage">
                                                <property name="title">tab1</property>
                                                <property name="child">
                                                    <object class="GtkLabel">
                                                        <property name="label">this is tab1</property>
                                                    </object>
                                                </property>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="AdwTabPage">
                                                <property name="title">tab2</property>
                                                <property name="child">
                                                    <object class="GtkLabel">
                                                        <property name="label">this is tab2</property>
                                                    </object>
                                                </property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </property>
            </object>
        </child>
    </object>
</interface>